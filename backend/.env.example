# Copia este archivo como ".env" y rellena los valores.
# Este .env NO se sube a git (ver .gitignore).

NODE_ENV=development
PORT=3000

# Base de datos — si ejecutas el backend con Docker Compose, DB_HOST debe ser
# "postgres" (nombre del servicio). Si lo ejecutas suelto en tu máquina
# contra los puertos publicados por docker-compose, usa "localhost".
DB_HOST=localhost
DB_PORT=5432
DB_USER=rally_user
DB_PASSWORD=rally_pass_dev
DB_NAME=rally_db

# Redis (igual que arriba: "redis" dentro de Docker, "localhost" fuera)
REDIS_URL=redis://localhost:6379

# JWT — cambiar SIEMPRE en producción por un secreto largo y aleatorio
# Generar uno con: openssl rand -hex 64
JWT_SECRET=dev_secret_key_change_in_production
JWT_ACCESS_EXPIRES=1h
JWT_REFRESH_EXPIRES_DAYS=30

# SMTP para verificación de email (Resend, SendGrid, etc.)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# CORS — orígenes permitidos para el frontend web y la app móvil
WEB_URL=http://localhost:5173
MOBILE_URL=http://localhost:8081
